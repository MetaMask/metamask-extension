# Agent eval harness credentials
# Copy to .agents.env and fill in values.
# .agents.env is gitignored — never commit secrets.

# Required: Anthropic API key (or LiteLLM proxy key)
ANTHROPIC_API_KEY=

# Optional: LiteLLM proxy base URL (omit to use Anthropic directly)
# ANTHROPIC_BASE_URL=http://localhost:4000

# Optional: Langfuse telemetry (required when --telemetry is enabled)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
