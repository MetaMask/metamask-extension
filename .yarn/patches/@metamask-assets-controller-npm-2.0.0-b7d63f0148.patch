     // ============================================================================
+    // CURRENT CURRENCY MANAGEMENT
+    // ============================================================================
+    /**
+     * Set the current currency.
+     *
+     * @param currentCurrency - The ISO 4217 currency code to set.
+     */
+    setCurrentCurrency(currentCurrency) {
+        const previousCurrency = this.state.currentCurrency;
+        if (previousCurrency === currentCurrency) {
+            return;
+        }
+        this.update((state) => {
+            state.currentCurrency = currentCurrency;
+        });
+        log('Current currency changed', {
+            previousCurrency,
+            currentCurrency,
+        });
+        this.getAssets(__classPrivateFieldGet(this, _AssetsController_instances, "a", _AssetsController_selectedAccounts_get), {
+            forceUpdate: true,
+            dataTypes: ['price'],
+        }).catch((error) => {
+            log('Failed to fetch asset prices after current currency change', error);
+        });
+    }
