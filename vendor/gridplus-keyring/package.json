{
  "name": "@gridplus/keyring",
  "version": "0.0.1-local",
  "description": "GridPlus Lattice keyring for MetaMask using the GridPlus Connect API",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.cts",
  "exports": {
    ".": {
      "types": "./index.d.cts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.mjs"
    }
  },
  "dependencies": {
    "@gridplus/types": "file:../gridplus-types",
    "eventemitter3": "^5.0.1"
  },
  "peerDependencies": {
    "@ethereumjs/tx": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@ethereumjs/tx": {
      "optional": true
    }
  },
  "license": "MIT"
}
