{
  "name": "@dial-wtf/react",
  "version": "0.3.0",
  "description": "React hooks and context provider for the Dial SDK",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@dial-wtf/client": "file:../dial-client",
    "@dial-wtf/core": "file:../dial-core"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
