{
  "name": "@dial-wtf/core",
  "version": "0.3.0",
  "description": "Dial SDK core - Platform-agnostic types, errors, and protocol interfaces",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
