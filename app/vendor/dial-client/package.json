{
  "name": "@dial-wtf/client",
  "version": "0.3.0",
  "description": "Dial SDK client - Universal TypeScript SDK for wallet-to-wallet communication",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "import": "./dist/media/index.js",
      "require": "./dist/media/index.cjs"
    },
    "./media/hms": {
      "types": "./dist/media/hms.d.ts",
      "import": "./dist/media/hms.js",
      "require": "./dist/media/hms.cjs"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@dial-wtf/core": "file:../dial-core",
    "eventemitter3": "^5.0.1"
  },
  "peerDependencies": {
    "@100mslive/hms-video-store": ">=0.12.0",
    "siwe": "^2.1.4"
  },
  "peerDependenciesMeta": {
    "siwe": {
      "optional": true
    },
    "@100mslive/hms-video-store": {
      "optional": true
    }
  }
}
