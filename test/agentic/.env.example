# test/agentic/.env — sandbox configuration for this worktree.
#
# Copy to test/agentic/.env (gitignored) and edit. Anything you don't set here
# stays at the default in sandbox.sh. Real shell env vars override this file —
# unset them when you want the file's value back.
#
# Pick a unique CDP_PORT per worktree to avoid collisions when running multiple
# sandboxes on the same machine.

# CDP / window
export CDP_PORT=9222
export SANDBOX_LABEL=agentic
# export LAUNCH_MODE=fullscreen        # or "sidepanel"

# Paths (defaults shown; customize for farmslot or shared layouts)
# export RUNTIME_DIR=temp/runtime      # farmslot exports RUNTIME_DIR=.agent
# export WALLET_FIXTURE=temp/runtime/wallet-fixture.json
# export EXTENSION_DIR=dist/chrome
# export PROFILE_NAME=chrome-profile-pw

# Build wait
# export BUILD_TIMEOUT=180
