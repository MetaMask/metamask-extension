{
  "description": "Idempotently enables testnet mode via perpsToggleTestnet RPC, verifies the store reflects testnet, and waits for markets to load.",
  "title": "Setup testnet mode",
  "validate": {
    "workflow": {
      "pre_conditions": ["wallet.unlocked", "perps.feature_enabled"],
      "entry": "check-state",
      "nodes": {
        "check-state": {
          "action": "eval_sync",
          "expression": "(function(){var m=stateHooks.store.getState().metamask;return JSON.stringify({isTestnet:!!m.isTestnet})})()",
          "save_as": "net_state",
          "next": "branch-state"
        },
        "branch-state": {
          "action": "switch",
          "cases": [
            {
              "label": "already on testnet — skip toggle",
              "when": {
                "field": "vars.net_state.isTestnet",
                "operator": "eq",
                "value": true
              },
              "next": "verify-testnet"
            }
          ],
          "default": "toggle-testnet"
        },
        "toggle-testnet": {
          "action": "toggle_testnet",
          "next": "verify-testnet"
        },
        "verify-testnet": {
          "action": "wait_for",
          "expression": "(function(){var m=stateHooks.store.getState().metamask;return JSON.stringify({isTestnet:!!m.isTestnet})})()",
          "assert": { "operator": "eq", "field": "isTestnet", "value": true },
          "timeout_ms": 5000,
          "poll_ms": 500,
          "next": "verify-markets"
        },
        "verify-markets": {
          "action": "wait_for",
          "expression": "(async()=>{var r=await stateHooks.submitRequestToBackground('perpsGetMarketDataWithPrices',[]);return JSON.stringify({count:(r??[]).length})})()",
          "assert": { "operator": "gt", "field": "count", "value": 0 },
          "timeout_ms": 15000,
          "poll_ms": 1000,
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
