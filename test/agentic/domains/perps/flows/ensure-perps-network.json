{
  "title": "Ensure perps network: {{network}} / {{provider}}",
  "description": "Ensures the perps network and provider match the requested state. Idempotent — skips toggle/switch if already correct.",
  "inputs": {
    "network": {
      "type": "string",
      "default": "testnet",
      "description": "Target network (testnet or mainnet)"
    },
    "provider": {
      "type": "string",
      "default": "hyperliquid",
      "description": "Target provider"
    }
  },
  "validate": {
    "workflow": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.feature_enabled"
      ],
      "setup": [
        {
          "id": "setup-prime-perps",
          "action": "call",
          "ref": "perps/prime-perps-state"
        }
      ],
      "entry": "check-state",
      "nodes": {
        "check-state": {
          "action": "eval_sync",
          "expression": "(function(){var m=stateHooks.store.getState().metamask;var wantTestnet='{{network}}'==='testnet';var networkOk=!!m.isTestnet===wantTestnet;var providerOk=(m.activeProvider||'unknown')==='{{provider}}';return JSON.stringify({networkOk:networkOk,providerOk:providerOk,isTestnet:!!m.isTestnet,provider:m.activeProvider||'unknown'})})()",
          "save_as": "net_state",
          "next": "branch-network"
        },
        "branch-network": {
          "action": "switch",
          "cases": [
            {
              "label": "network mismatch — toggle",
              "when": { "field": "vars.net_state.networkOk", "operator": "eq", "value": false },
              "next": "toggle-network"
            }
          ],
          "default": "branch-provider"
        },
        "toggle-network": {
          "action": "toggle_testnet",
          "next": "verify-network"
        },
        "verify-network": {
          "action": "wait_for",
          "expression": "(function(){var m=stateHooks.store.getState().metamask;var want='{{network}}'==='testnet';return JSON.stringify({ok:!!m.isTestnet===want})})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "timeout_ms": 5000,
          "poll_ms": 500,
          "next": "reload-ui"
        },
        "reload-ui": {
          "action": "eval_async",
          "expression": "(async()=>{location.reload();return JSON.stringify({reloaded:true})})()",
          "next": "wait-reload"
        },
        "wait-reload": {
          "action": "wait_for",
          "test_id": "account-menu-icon",
          "timeout_ms": 15000,
          "next": "branch-provider"
        },
        "branch-provider": {
          "action": "switch",
          "cases": [
            {
              "label": "provider mismatch — switch",
              "when": { "field": "vars.net_state.providerOk", "operator": "eq", "value": false },
              "next": "switch-provider"
            }
          ],
          "default": "verify-markets"
        },
        "switch-provider": {
          "action": "switch_provider",
          "provider": "{{provider}}",
          "next": "verify-markets"
        },
        "verify-markets": {
          "action": "wait_for",
          "expression": "(async()=>{var r=await stateHooks.submitRequestToBackground('perpsGetMarketDataWithPrices',[]);return JSON.stringify({count:(r??[]).length})})()",
          "assert": { "operator": "gt", "field": "count", "value": 0 },
          "timeout_ms": 15000,
          "poll_ms": 1000,
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
