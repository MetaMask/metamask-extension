{
  "inputs": {
    "side": {
      "type": "string",
      "default": "long",
      "description": "Trade side (long/short)"
    },
    "symbol": {
      "type": "string",
      "default": "ETH",
      "description": "Market symbol"
    },
    "amount": {
      "type": "string",
      "default": "10",
      "description": "USD notional amount"
    }
  },
  "title": "Trade — market {{side}} {{symbol}} ${{amount}}",
  "validate": {
    "workflow": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.feature_enabled",
        "perps.ready_to_trade",
        "perps.sufficient_balance"
      ],
      "setup": [
        {
          "id": "setup-prime-perps",
          "action": "call",
          "ref": "perps/prime-perps-state"
        }
      ],
      "entry": "gate-check-balance",
      "nodes": {
        "gate-check-balance": {
          "action": "eval_async",
          "expression": "(async()=>{var r=await stateHooks.submitRequestToBackground('perpsGetAccountState',[]);var bal=parseFloat(r?.totalBalance??'0');return JSON.stringify({ok:bal>0,bal:bal,reason:bal>0?'ok':'Insufficient perps balance ($'+bal+') — deposit funds (mainnet) or use a funded testnet account'})})()",
          "assert": {
            "operator": "eq",
            "field": "ok",
            "value": true
          },
          "save_as": "balance_gate",
          "next": "call-nav-detail"
        },
        "call-nav-detail": {
          "action": "call",
          "ref": "perps/navigate-to-market-detail",
          "params": {
            "symbol": "{{symbol}}"
          },
          "next": "check-position"
        },
        "check-position": {
          "action": "ext_check_dom",
          "test_id": "perps-position-cta-buttons",
          "query": true,
          "save_as": "pos_check",
          "next": "branch-position"
        },
        "branch-position": {
          "action": "switch",
          "cases": [
            {
              "label": "position exists — skip order",
              "when": {
                "field": "vars.pos_check.visible",
                "operator": "truthy"
              },
              "next": "verify-position"
            }
          ],
          "default": "wait-detail"
        },
        "wait-detail": {
          "action": "wait_for",
          "test_id": "perps-{{side}}-cta-button",
          "timeout_ms": 10000,
          "next": "press-side"
        },
        "press-side": {
          "action": "press",
          "test_id": "perps-{{side}}-cta-button",
          "next": "wait-order-form"
        },
        "wait-order-form": {
          "action": "wait_for",
          "test_id": "perps-order-entry-page",
          "timeout_ms": 10000,
          "next": "set-amount"
        },
        "set-amount": {
          "action": "set_input",
          "test_id": "amount-input-field",
          "value": "{{amount}}",
          "next": "submit-order"
        },
        "submit-order": {
          "action": "press",
          "test_id": "submit-order-button",
          "next": "wait-submitted"
        },
        "wait-submitted": {
          "action": "wait_for",
          "test_id": "perps-market-detail-page",
          "timeout_ms": 15000,
          "next": "verify-position"
        },
        "verify-position": {
          "action": "wait_for",
          "test_id": "perps-position-cta-buttons",
          "timeout_ms": 10000,
          "next": "screenshot-result"
        },
        "screenshot-result": {
          "action": "screenshot",
          "filename": "{{side}}-position-{{symbol}}",
          "next": "done",
          "note": "Evidence capture: {{side}} position {{symbol}}"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
