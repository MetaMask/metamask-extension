{
  "title": "Send {{amount}} ETH to {{recipient}}",
  "inputs": {
    "amount": {
      "type": "string",
      "default": "0.001",
      "description": "Amount of ETH to send"
    },
    "recipient": {
      "type": "string",
      "default": "0x1234567890abcdef1234567890abcdef12345678",
      "description": "Recipient address"
    }
  },
  "validate": {
    "workflow": {
      "pre_conditions": ["wallet.unlocked"],
      "entry": "navigate-home",
      "nodes": {
        "navigate-home": {
          "action": "navigate",
          "target": "Home",
          "next": "press-send"
        },
        "press-send": {
          "action": "press",
          "test_id": "eth-overview-send",
          "next": "wait-send-form"
        },
        "wait-send-form": {
          "action": "wait_for",
          "test_id": "send-page",
          "timeout_ms": 10000,
          "next": "type-recipient"
        },
        "type-recipient": {
          "action": "set_input",
          "test_id": "ens-input",
          "value": "{{recipient}}",
          "next": "wait-resolve"
        },
        "wait-resolve": {
          "action": "wait",
          "ms": 1500,
          "next": "press-continue"
        },
        "press-continue": {
          "action": "press",
          "test_id": "send-page-next-button",
          "next": "wait-amount-form"
        },
        "wait-amount-form": {
          "action": "wait_for",
          "test_id": "currency-input",
          "timeout_ms": 10000,
          "next": "type-amount"
        },
        "type-amount": {
          "action": "set_input",
          "test_id": "currency-input",
          "value": "{{amount}}",
          "next": "press-next"
        },
        "press-next": {
          "action": "press",
          "test_id": "send-page-next-button",
          "next": "wait-confirmation"
        },
        "wait-confirmation": {
          "action": "wait_for",
          "test_id": "confirm-footer-button",
          "timeout_ms": 15000,
          "next": "press-confirm"
        },
        "press-confirm": {
          "action": "press",
          "test_id": "confirm-footer-button",
          "next": "wait-complete"
        },
        "wait-complete": {
          "action": "wait_for",
          "test_id": "account-overview",
          "timeout_ms": 30000,
          "next": "screenshot-result"
        },
        "screenshot-result": {
          "action": "screenshot",
          "filename": "send-eth-complete",
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
