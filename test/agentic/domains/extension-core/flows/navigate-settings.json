{
  "title": "Navigate to Settings page",
  "validate": {
    "workflow": {
      "pre_conditions": ["wallet.unlocked"],
      "entry": "nav-settings",
      "nodes": {
        "nav-settings": {
          "action": "navigate",
          "target": "Settings",
          "next": "wait-settings-page"
        },
        "wait-settings-page": {
          "action": "wait_for",
          "route": "settings",
          "timeout_ms": 10000,
          "next": "screenshot-settings"
        },
        "screenshot-settings": {
          "action": "screenshot",
          "filename": "settings-page",
          "next": "done",
          "note": "Evidence capture: settings page"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}
