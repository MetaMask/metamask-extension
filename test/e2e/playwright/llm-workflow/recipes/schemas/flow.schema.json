{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flow.schema.json",
  "title": "Agentic Flow",
  "type": "object",
  "required": ["title", "validate"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "description": "Human-readable title. May contain {{param}} template tokens."
    },
    "pr": {
      "type": ["string", "number"],
      "description": "Associated PR number (informational)."
    },
    "inputs": {
      "type": "object",
      "description": "Declared parameters. Every {{param}} used in steps MUST have a matching key.",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["string", "number", "boolean"] },
          "default": { "description": "Default value. Single source of truth." },
          "description": { "type": "string" }
        }
      }
    },
    "initial_conditions": {
      "type": "object",
      "properties": {
        "account": { "type": "string" },
        "testnet": { "type": "boolean" },
        "provider": { "type": "string" }
      }
    },
    "validate": {
      "type": "object",
      "required": ["runtime"],
      "properties": {
        "runtime": {
          "type": "object",
          "required": ["steps"],
          "properties": {
            "pre_conditions": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "description": "Named pre-condition (e.g. 'wallet.unlocked')"
                  },
                  {
                    "type": "object",
                    "required": ["name"],
                    "description": "Parameterized (e.g. { name: 'ext.element_visible', testId: 'app-header' })"
                  }
                ]
              }
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/step" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "action"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique kebab-case identifier for this step."
        },
        "action": {
          "type": "string",
          "enum": [
            "press",
            "set_input",
            "type_keypad",
            "clear_keypad",
            "navigate",
            "wait",
            "wait_for",
            "screenshot",
            "eval_sync",
            "eval_async",
            "eval_ref",
            "flow_ref",
            "log_watch",
            "scroll",
            "manual",
            "select_account",
            "toggle_testnet",
            "switch_provider",
            "ext_navigate_hash",
            "ext_wait_for_screen",
            "ext_switch_tab",
            "ext_check_dom"
          ]
        },
        "test_id": { "type": "string" },
        "value": { "type": "string" },
        "target": { "type": "string" },
        "params": { "type": "object", "additionalProperties": { "type": "string" } },
        "ref": { "type": "string" },
        "ms": { "type": "number" },
        "timeout_ms": { "type": "number" },
        "poll_ms": { "type": "number" },
        "expression": { "type": "string" },
        "filename": { "type": "string" },
        "note": { "type": "string" },
        "route": { "type": "string" },
        "not_route": { "type": "string" },
        "visible": { "type": "boolean" },
        "hash": { "type": "string" },
        "screen": { "type": "string" },
        "role": { "type": "string" },
        "selector": { "type": "string" },
        "attribute": { "type": "string" },
        "text": { "type": "string" },
        "offset": { "type": "number" },
        "must_not_appear": { "type": "array", "items": { "type": "string" } },
        "watch_for": { "type": "array", "items": { "type": "string" } },
        "window_seconds": { "type": "number" },
        "enabled": { "type": "boolean" },
        "provider": { "type": "string" },
        "address": { "type": "string" },
        "assert": { "$ref": "#/$defs/assert" }
      }
    },
    "assert": {
      "type": "object",
      "required": ["operator"],
      "properties": {
        "operator": {
          "type": "string",
          "enum": [
            "not_null",
            "eq",
            "neq",
            "gt",
            "length_eq",
            "length_gt",
            "contains",
            "not_contains"
          ]
        },
        "field": { "type": "string" },
        "value": {}
      }
    }
  }
}
