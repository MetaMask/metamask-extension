{
  "title": "Navigate to Perps tab",
  "validate": {
    "runtime": {
      "pre_conditions": ["wallet.unlocked"],
      "steps": [
        {
          "id": "go-home",
          "action": "navigate",
          "target": "Home"
        },
        {
          "id": "wait-home-screen",
          "action": "wait_for",
          "test_id": "account-menu-icon",
          "timeout_ms": 10000
        },
        {
          "id": "click-perps-tab",
          "action": "press",
          "test_id": "account-overview__perps-tab"
        },
        {
          "id": "wait-perps-view",
          "action": "wait_for",
          "test_id": "perps-tab-view",
          "timeout_ms": 10000
        },
        {
          "id": "verify-perps-tab",
          "action": "ext_check_dom",
          "test_id": "perps-tab-view",
          "visible": true,
          "assert": {
            "operator": "not_null"
          }
        },
        {
          "id": "screenshot-perps",
          "action": "screenshot",
          "filename": "perps-tab"
        }
      ]
    }
  }
}
