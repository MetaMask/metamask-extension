{
  "title": "Trade — market {{side}} {{symbol}} ${{amount}}",
  "inputs": {
    "side": {
      "type": "string",
      "default": "long",
      "description": "Trade side (long/short)"
    },
    "symbol": {
      "type": "string",
      "default": "ETH",
      "description": "Market symbol"
    },
    "amount": {
      "type": "string",
      "default": "10",
      "description": "USD notional amount"
    }
  },
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.feature_enabled",
        "perps.ready_to_trade",
        "perps.sufficient_balance"
      ],
      "steps": [
        {
          "id": "nav-perps",
          "action": "press",
          "test_id": "account-overview__perps-tab"
        },
        {
          "id": "wait-market",
          "action": "wait_for",
          "test_id": "explore-crypto-{{symbol}}",
          "timeout_ms": 10000
        },
        {
          "id": "select-market",
          "action": "press",
          "test_id": "explore-crypto-{{symbol}}"
        },
        {
          "id": "wait-detail",
          "action": "wait_for",
          "test_id": "perps-{{side}}-cta-button",
          "timeout_ms": 10000
        },
        {
          "id": "press-side",
          "action": "press",
          "test_id": "perps-{{side}}-cta-button"
        },
        {
          "id": "wait-order-form",
          "action": "wait_for",
          "test_id": "perps-order-entry-page",
          "timeout_ms": 10000
        },
        {
          "id": "set-amount",
          "action": "set_input",
          "test_id": "amount-input-field",
          "value": "{{amount}}"
        },
        {
          "id": "submit-order",
          "action": "press",
          "test_id": "submit-order-button"
        },
        {
          "id": "wait-submitted",
          "action": "wait_for",
          "test_id": "perps-market-detail-page",
          "timeout_ms": 15000
        },
        {
          "id": "verify-position",
          "action": "wait_for",
          "test_id": "perps-position-cta-buttons",
          "timeout_ms": 10000
        },
        {
          "id": "screenshot-result",
          "action": "screenshot",
          "filename": "{{side}}-position-{{symbol}}"
        }
      ]
    }
  }
}
