{
  "title": "Send {{amount}} ETH to {{recipient}}",
  "inputs": {
    "amount": {
      "type": "string",
      "default": "0.001",
      "description": "Amount of ETH to send"
    },
    "recipient": {
      "type": "string",
      "default": "0x1234567890abcdef1234567890abcdef12345678",
      "description": "Recipient address"
    }
  },
  "validate": {
    "runtime": {
      "pre_conditions": ["wallet.unlocked"],
      "steps": [
        {
          "id": "navigate-home",
          "action": "navigate",
          "target": "Home"
        },
        {
          "id": "press-send",
          "action": "press",
          "test_id": "eth-overview-send"
        },
        {
          "id": "wait-send-form",
          "action": "wait_for",
          "test_id": "send-page",
          "timeout_ms": 10000
        },
        {
          "id": "type-recipient",
          "action": "set_input",
          "test_id": "ens-input",
          "value": "{{recipient}}"
        },
        {
          "id": "wait-resolve",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "press-continue",
          "action": "press",
          "test_id": "send-page-next-button"
        },
        {
          "id": "wait-amount-form",
          "action": "wait_for",
          "test_id": "currency-input",
          "timeout_ms": 10000
        },
        {
          "id": "type-amount",
          "action": "set_input",
          "test_id": "currency-input",
          "value": "{{amount}}"
        },
        {
          "id": "press-next",
          "action": "press",
          "test_id": "send-page-next-button"
        },
        {
          "id": "wait-confirmation",
          "action": "wait_for",
          "test_id": "confirm-footer-button",
          "timeout_ms": 15000
        },
        {
          "id": "press-confirm",
          "action": "press",
          "test_id": "confirm-footer-button"
        },
        {
          "id": "wait-complete",
          "action": "wait_for",
          "test_id": "account-overview",
          "timeout_ms": 30000
        },
        {
          "id": "screenshot-result",
          "action": "screenshot",
          "filename": "send-eth-complete"
        }
      ]
    }
  }
}
