{
  "title": "Navigate to Settings page",
  "validate": {
    "runtime": {
      "pre_conditions": ["wallet.unlocked"],
      "steps": [
        {
          "id": "click-account-menu",
          "action": "press",
          "test_id": "account-options-menu-button"
        },
        {
          "id": "wait-menu",
          "action": "wait_for",
          "test_id": "global-menu-settings",
          "timeout_ms": 5000
        },
        {
          "id": "click-settings",
          "action": "press",
          "test_id": "global-menu-settings"
        },
        {
          "id": "wait-settings-page",
          "action": "wait_for",
          "route": "settings",
          "timeout_ms": 10000
        },
        {
          "id": "screenshot-settings",
          "action": "screenshot",
          "filename": "settings-page"
        }
      ]
    }
  }
}
